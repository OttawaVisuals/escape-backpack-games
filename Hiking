<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Escape Backpack</title>
<link href="https://fonts.googleapis.com/css2?family=Quantico:wght@400;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#090b0f;--surf:#0f1117;--surf2:#151820;--brd:#1c2030;
  --acc:#00d9f5;--grn:#00e896;--red:#ff4060;--warn:#ffb800;
  --text:#dde1ed;--muted:#424860;
  --mono:'Share Tech Mono',monospace;--sans:'Quantico',sans-serif;--r:8px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{min-height:100%}
body{background:var(--bg);color:var(--text);font-family:var(--sans);-webkit-font-smoothing:antialiased;
  background-image:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,217,245,.012) 3px,rgba(0,217,245,.012) 4px)}

.screen{display:none;justify-content:center;min-height:100vh;padding:24px 16px 48px}
.screen.on{display:flex}
.wrap{width:100%;max-width:560px;display:flex;flex-direction:column;gap:16px}

.card{background:var(--surf);border:1px solid var(--brd);border-radius:var(--r);padding:20px;width:100%}
.lbl{font-size:.62rem;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:14px}

.field{display:flex;flex-direction:column;gap:7px}
.fl{font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted)}
input[type=text]{width:100%;background:var(--bg);border:1px solid var(--brd);border-radius:var(--r);
  color:var(--text);font-family:var(--sans);font-size:1rem;padding:13px 14px;outline:none;
  -webkit-appearance:none;transition:border-color .18s,box-shadow .18s}
input[type=text]:focus{border-color:var(--acc);box-shadow:0 0 0 3px rgba(0,217,245,.1)}

.btn{display:inline-flex;align-items:center;justify-content:center;gap:7px;
  font-family:var(--sans);font-size:.78rem;font-weight:700;letter-spacing:.13em;text-transform:uppercase;
  border:none;border-radius:var(--r);padding:12px 16px;cursor:pointer;touch-action:manipulation;
  transition:opacity .15s,transform .1s,box-shadow .15s}
.btn:active{transform:scale(.97)}
.btn:disabled{opacity:.3;cursor:not-allowed;transform:none}
.btn-go{background:var(--acc);color:#050710}
.btn-go:hover:not(:disabled){box-shadow:0 0 28px rgba(0,217,245,.4)}
.btn-ghost{background:transparent;color:var(--muted);border:1px solid var(--brd)}
.btn-ghost:hover{color:var(--text);border-color:var(--muted)}
.btn-success{background:var(--grn);color:#050710}
.btn-success:hover{box-shadow:0 0 28px rgba(0,232,150,.35)}
.btn-danger{background:transparent;color:var(--red);border:1px solid rgba(255,64,96,.4)}
.btn-danger:hover{background:rgba(255,64,96,.08)}
.btn-full{width:100%}

/* SPLASH */
.splash{text-align:center;padding:8px 0}
.splash h1{font-size:clamp(1.8rem,7vw,2.6rem);font-weight:700;letter-spacing:.07em;text-transform:uppercase;line-height:1.1}
.splash h1 em{font-style:normal;color:var(--acc)}
.splash p{margin-top:8px;font-size:.7rem;letter-spacing:.13em;color:var(--muted);text-transform:uppercase}

/* TIMER */
.timer-val{font-family:var(--mono);font-size:clamp(3rem,12vw,5rem);color:var(--acc);
  text-align:center;letter-spacing:.06em;line-height:1;padding:4px 0;transition:color .3s}
.timer-val.paused{color:var(--warn);animation:tblink 1.1s ease-in-out infinite}
@keyframes tblink{0%,100%{opacity:1}50%{opacity:.4}}
.timer-sub{text-align:center;font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-top:8px}
.tctrl{display:flex;gap:8px;margin-top:14px}
.tctrl .btn{flex:1;padding:11px 6px;font-size:.7rem}

/* PROGRESS */
.prog-wrap{height:5px;background:var(--brd);border-radius:3px;margin-top:14px;overflow:hidden}
.prog-bar{height:100%;background:var(--grn);border-radius:3px;transition:width .4s ease}
.prog-lbl{text-align:center;font-size:.62rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-top:7px}

/* LOCK GRID */
.lock-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px}

.lc{display:flex;flex-direction:column;align-items:center;gap:5px;
  border-radius:var(--r);padding:8px 4px 10px;transition:opacity .2s,transform .15s;
  background:var(--surf2);border:2px solid transparent}
.lc.done{opacity:.55}
.lc.active{transform:scale(1.04)}

/* Lock colour themes matching the PNG border colours */
.lc.theme-blue  { border-color: #156082; }
.lc.theme-orange{ border-color: #C04F15; }
.lc.theme-purple{ border-color: #50164A; }
.lc.done.theme-blue  { border-color: var(--grn); background:#071510; }
.lc.done.theme-orange{ border-color: var(--grn); background:#071510; }
.lc.done.theme-purple{ border-color: var(--grn); background:#071510; }

.li-wrap{width:100%;aspect-ratio:1/1;display:flex;align-items:center;justify-content:center}
.li-wrap img{width:100%;height:100%;object-fit:contain;display:block}

.lnum{font-size:.55rem;letter-spacing:.1em;color:var(--muted);font-family:var(--mono)}
.lc.done .lnum{color:var(--grn)}

.lbtns{display:flex;gap:4px}
.lb{width:26px;height:26px;border-radius:5px;border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;font-size:.8rem;
  font-weight:700;touch-action:manipulation;transition:transform .1s,background .15s,color .15s}
.lb:active{transform:scale(.9)}
.lb-done{background:rgba(0,232,150,.12);color:var(--grn);border:1px solid rgba(0,232,150,.25)}
.lb-done.on{background:var(--grn);color:#050710;border-color:var(--grn)}
.lb-hint{background:rgba(0,217,245,.1);color:var(--acc);border:1px solid rgba(0,217,245,.2)}
.lb-hint.on{background:var(--acc);color:#050710;border-color:var(--acc)}

/* HINT PANEL */
#hint-panel{display:none;width:100%}
#hint-panel.on{display:block}
.hint-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.hint-title{font-size:.88rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--acc)}
.hint-x{background:none;border:1px solid var(--brd);border-radius:var(--r);color:var(--muted);
  font-size:.75rem;cursor:pointer;padding:5px 10px;font-family:var(--sans);letter-spacing:.08em;text-transform:uppercase}
.hint-x:hover{color:var(--text);border-color:var(--muted)}

.hs{border-top:1px solid var(--brd)}
.hs:last-child{border-bottom:1px solid var(--brd)}
.ht{width:100%;display:flex;align-items:center;justify-content:space-between;
  background:none;border:none;padding:13px 0;cursor:pointer;
  font-family:var(--sans);font-size:.76rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  color:var(--text);text-align:left}
.ht:hover{color:var(--acc)}
.chev{font-size:.65rem;color:var(--muted);transition:transform .2s;flex-shrink:0;margin-left:8px}
.ht.open .chev{transform:rotate(90deg)}
.hb{display:none;padding-bottom:16px;font-size:.9rem;line-height:1.7;color:var(--text)}
.hb.on{display:block}
.hb img{max-width:100%;border-radius:var(--r);margin:10px 0;display:block}
.c1{color:var(--warn)}.c2{color:#ff9040}.c3{color:var(--red)}.c4{color:var(--grn)}

/* COMPLETE */
.congrats{text-align:center;padding:16px 0}
.big-check{font-size:3.5rem;margin-bottom:14px}
.ctime{font-family:var(--mono);font-size:clamp(2.8rem,11vw,4.5rem);color:var(--grn);letter-spacing:.06em;line-height:1}
.cteam{margin-top:10px;font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted)}
.clocks{font-family:var(--mono);font-size:.85rem;color:var(--acc);margin-top:6px}
.cmsg{margin-top:18px;font-size:.95rem;line-height:1.6;color:var(--text);
  padding:14px;background:rgba(0,232,150,.07);border:1px solid rgba(0,232,150,.2);border-radius:var(--r)}
</style>
</head>
<body>

<!-- SETUP -->
<div class="screen on" id="s-setup">
  <div class="wrap">
    <div class="splash">
      <h1>Ready to<br><em>Escape?</em></h1>
      <p>Enter your team name to begin</p>
    </div>
    <div class="card">
      <div class="lbl">Team Name</div>
      <div class="field">
        <label class="fl" for="inp-team">Your team</label>
        <input type="text" id="inp-team" placeholder="e.g. Team Alpha" maxlength="40"
               autocomplete="off" oninput="chkSetup()" onkeydown="if(event.key==='Enter')startGame()">
      </div>
    </div>
    <button class="btn btn-go btn-full" id="btn-start" disabled onclick="startGame()">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      Start Timer
    </button>
    <button class="btn btn-ghost btn-full" id="btn-resume" style="display:none" onclick="resumeGame()">
      ↩ Resume Previous Session
    </button>
  </div>
</div>

<!-- GAME -->
<div class="screen" id="s-game">
  <div class="wrap">
    <div class="card">
      <div class="timer-val" id="g-timer">00:00</div>
      <div class="timer-sub" id="g-team">—</div>
      <div class="tctrl">
        <button class="btn btn-ghost" id="btn-pause" onclick="togglePause()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path id="pause-icon" d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
          <span id="pause-lbl">Pause</span>
        </button>
        <button class="btn btn-danger" onclick="confirmReset()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.65 6.35A7.958 7.958 0 0012 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0112 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
          Reset
        </button>
        <button class="btn btn-success" onclick="confirmComplete()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Complete!
        </button>
      </div>
      <div class="prog-wrap"><div class="prog-bar" id="prog-bar" style="width:0%"></div></div>
      <div class="prog-lbl" id="prog-lbl">0 / 10 locks solved</div>
    </div>

    <div class="card">
      <div class="lbl">Locks</div>
      <div class="lock-grid" id="lock-grid"></div>
    </div>

    <div class="card" id="hint-panel">
      <div class="hint-hdr">
        <div class="hint-title" id="hint-title">Lock 1 — Hints</div>
        <button class="hint-x" onclick="closeHint()">✕ Close</button>
      </div>
      <div id="hint-sections"></div>
    </div>
  </div>
</div>

<!-- COMPLETE -->
<div class="screen" id="s-complete">
  <div class="wrap">
    <div class="card">
      <div class="congrats">
        <div class="big-check">🎉</div>
        <div class="ctime" id="c-time">00:00</div>
        <div class="cteam" id="c-team">—</div>
        <div class="clocks" id="c-locks">— / 10 locks solved</div>
        <div class="cmsg" id="c-msg"></div>
      </div>
    </div>
    <button class="btn btn-ghost btn-full" onclick="resetAll()">↩ Play Again</button>
  </div>
</div>

<script>
// ═══════════════════════ CONFIG ═══════════════════════
const LOGGER_URL    = 'YOUR_APPS_SCRIPT_LOGGER_URL_HERE';
const BACKPACK_NAME = 'Hiking Backpack';

// Colour theme per lock (matching PNG border colours)
const LOCK_THEMES = ['blue','blue','blue','blue','blue','orange','orange','orange','orange','purple'];

const HINT_LEVELS = [
  { label: '💡 Hint #1', cls: 'c1' },
  { label: '💡 Hint #2', cls: 'c2' },
  { label: '💡 Hint #3', cls: 'c3' },
  { label: '✅ Solution', cls: 'c4' }
];

const LOCKS = [
  {
    name: 'Lock 1 — Start of the backpack',
    hints: [
      'Look closely at the water bottle that is on the side of the backpack.',
      'On the water bottle, you will find animals that might have something special on them.',
      'Some numbers are hidden on the animals. The order in which to put them might be related to the era of each animal.<br><img src="data:image/png;base64," alt="Animals on water bottle" style="max-width:100%;border-radius:8px;margin:10px 0;display:block">',
      'Solution is: <strong style="font-family:var(--mono);font-size:1.3rem;letter-spacing:.12em;color:var(--grn)">749</strong>'
    ]
  },
  { name:'Lock 2', hints:['Hint 1 for lock 2.','Hint 2 for lock 2.','Hint 3 for lock 2.','Solution for lock 2.'] },
  { name:'Lock 3', hints:['Hint 1 for lock 3.','Hint 2 for lock 3.','Hint 3 for lock 3.','Solution for lock 3.'] },
  { name:'Lock 4', hints:['Hint 1 for lock 4.','Hint 2 for lock 4.','Hint 3 for lock 4.','Solution for lock 4.'] },
  { name:'Lock 5', hints:['Hint 1 for lock 5.','Hint 2 for lock 5.','Hint 3 for lock 5.','Solution for lock 5.'] },
  { name:'Lock 6', hints:['Hint 1 for lock 6.','Hint 2 for lock 6.','Hint 3 for lock 6.','Solution for lock 6.'] },
  { name:'Lock 7', hints:['Hint 1 for lock 7.','Hint 2 for lock 7.','Hint 3 for lock 7.','Solution for lock 7.'] },
  { name:'Lock 8', hints:['Hint 1 for lock 8.','Hint 2 for lock 8.','Hint 3 for lock 8.','Solution for lock 8.'] },
  { name:'Lock 9', hints:['Hint 1 for lock 9.','Hint 2 for lock 9.','Hint 3 for lock 9.','Solution for lock 9.'] },
  { name:'Lock 10', hints:['Hint 1 for lock 10.','Hint 2 for lock 10.','Hint 3 for lock 10.','Solution for lock 10.'] }
];

// ═══════════════════════ PNG ICONS ════════════════════
const LOCK_IMGS = [
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
  "data:image/png;base64,",
];

// ═══════════════════════ STATE ════════════════════════
const LS_KEY = 'escbp_' + BACKPACK_NAME.replace(/\s+/g,'_');

let st = {
  team:'', sessionId:'', startMs:0, elapsed:0,
  paused:false, pausedAt:0, active:false,
  completed: new Array(10).fill(false),
  hintLog:{}, lockTs:{}
};
let ticker    = null;
let activeHint = -1;

// ═══════════════════════ INIT ═════════════════════════
window.addEventListener('DOMContentLoaded', () => {
  buildGrid();
  const saved = loadSt();
  if (saved && saved.active) {
    document.getElementById('btn-resume').style.display = 'block';
  }
});

function chkSetup() {
  document.getElementById('btn-start').disabled =
    !document.getElementById('inp-team').value.trim();
}

// ═══════════════════════ GRID ═════════════════════════
function buildGrid() {
  const g = document.getElementById('lock-grid');
  g.innerHTML = '';
  LOCKS.forEach((lk, i) => {
    const d = document.createElement('div');
    d.className = 'lc theme-' + LOCK_THEMES[i];
    d.id = 'lc' + i;
    d.innerHTML = `
      <div class="li-wrap">
        <img src="${LOCK_IMGS[i]}" alt="Lock ${i+1}">
      </div>
      <div class="lnum">LOCK ${i+1}</div>
      <div class="lbtns">
        <button class="lb lb-done" id="db${i}"
          onclick="event.stopPropagation();toggleDone(${i})"
          title="Mark solved">✓</button>
        <button class="lb lb-hint" id="hb${i}"
          onclick="event.stopPropagation();toggleHint(${i})"
          title="Toggle hints">?</button>
      </div>`;
    g.appendChild(d);
  });
}

function updateGrid() {
  const n = st.completed.filter(Boolean).length;
  document.getElementById('prog-bar').style.width = (n / 10 * 100) + '%';
  document.getElementById('prog-lbl').textContent = `${n} / 10 locks solved`;
  for (let i = 0; i < 10; i++) {
    document.getElementById('lc' + i).classList.toggle('done', !!st.completed[i]);
    document.getElementById('db' + i).classList.toggle('on',   !!st.completed[i]);
  }
}

// ═══════════════════════ DONE — LINEAR ════════════════
function toggleDone(i) {
  const wasDone = st.completed[i];
  if (!wasDone) {
    // Mark this lock and all before it done
    for (let j = 0; j <= i; j++) {
      if (!st.completed[j]) {
        st.completed[j] = true;
        st.lockTs[j] = st.elapsed;
      }
    }
    // Log only the tapped lock
    logAsync({ event:'lock_solved', teamName:st.team, backpackName:BACKPACK_NAME,
               lockIndex:i+1, lockName:LOCKS[i].name,
               elapsedSeconds:st.elapsed, sessionId:st.sessionId });
  } else {
    // Unmark this lock and all after it
    for (let j = i; j < 10; j++) {
      st.completed[j] = false;
      delete st.lockTs[j];
    }
    if (activeHint >= i) closeHint();
  }
  updateGrid();
  saveSt();
}

// ═══════════════════════ HINTS ════════════════════════
function toggleHint(i) {
  activeHint === i ? closeHint() : openHint(i);
}

function openHint(i) {
  activeHint = i;
  for (let j = 0; j < 10; j++) {
    document.getElementById('hb' + j).classList.toggle('on', j === i);
    document.getElementById('lc' + j).classList.toggle('active', j === i);
  }
  document.getElementById('hint-title').textContent = LOCKS[i].name + ' — Hints';

  const sec = document.getElementById('hint-sections');
  sec.innerHTML = '';
  LOCKS[i].hints.forEach((txt, hi) => {
    const wrap = document.createElement('div');
    wrap.className = 'hs';
    const tog = document.createElement('button');
    tog.className = 'ht';
    tog.innerHTML = `<span class="${HINT_LEVELS[hi].cls}">${HINT_LEVELS[hi].label}</span><span class="chev">▶</span>`;
    const body = document.createElement('div');
    body.className = 'hb';
    body.innerHTML = txt;
    tog.onclick = () => {
      const wasOpen = tog.classList.contains('open');
      sec.querySelectorAll('.ht').forEach(t => t.classList.remove('open'));
      sec.querySelectorAll('.hb').forEach(b => b.classList.remove('on'));
      if (!wasOpen) {
        tog.classList.add('open');
        body.classList.add('on');
        if (!st.hintLog[i]) st.hintLog[i] = [];
        if (!st.hintLog[i].includes(hi)) {
          st.hintLog[i].push(hi);
          logAsync({ event:'hint_opened', teamName:st.team, backpackName:BACKPACK_NAME,
                     lockIndex:i+1, lockName:LOCKS[i].name, hintLevel:HINT_LEVELS[hi].label,
                     elapsedSeconds:st.elapsed, sessionId:st.sessionId });
        }
      }
    };
    wrap.appendChild(tog);
    wrap.appendChild(body);
    sec.appendChild(wrap);
  });

  document.getElementById('hint-panel').classList.add('on');
  setTimeout(() => document.getElementById('hint-panel')
    .scrollIntoView({ behavior:'smooth', block:'nearest' }), 80);
}

function closeHint() {
  activeHint = -1;
  document.getElementById('hint-panel').classList.remove('on');
  for (let j = 0; j < 10; j++) {
    document.getElementById('hb' + j).classList.remove('on');
    document.getElementById('lc' + j).classList.remove('active');
  }
}

// ═══════════════════════ TIMER ════════════════════════
function startTick() {
  clearInterval(ticker);
  ticker = setInterval(() => {
    if (!st.paused) {
      st.elapsed = Math.floor((Date.now() - st.startMs) / 1000);
      document.getElementById('g-timer').textContent = fmt(st.elapsed);
    }
    saveSt();
  }, 1000);
}

function togglePause() {
  if (st.paused) {
    st.startMs += Date.now() - st.pausedAt;
    st.paused   = false;
    document.getElementById('g-timer').classList.remove('paused');
    document.getElementById('pause-icon').setAttribute('d', 'M6 19h4V5H6v14zm8-14v14h4V5h-4z');
    document.getElementById('pause-lbl').textContent = 'Pause';
    logAsync({ event:'resume', elapsedSeconds:st.elapsed, sessionId:st.sessionId });
  } else {
    st.pausedAt = Date.now();
    st.paused   = true;
    document.getElementById('g-timer').classList.add('paused');
    document.getElementById('pause-icon').setAttribute('d', 'M8 5v14l11-7z');
    document.getElementById('pause-lbl').textContent = 'Resume';
    logAsync({ event:'pause', elapsedSeconds:st.elapsed, sessionId:st.sessionId });
  }
  saveSt();
}

// ═══════════════════════ GAME FLOW ════════════════════
function startGame() {
  const team = document.getElementById('inp-team').value.trim();
  if (!team) return;
  st = {
    team, sessionId: 's' + Date.now() + '_' + Math.random().toString(36).slice(2,5),
    startMs: Date.now(), elapsed: 0, paused: false, pausedAt: 0, active: true,
    completed: new Array(10).fill(false), hintLog: {}, lockTs: {}
  };
  activeHint = -1;
  logAsync({ event:'start', teamName:st.team, backpackName:BACKPACK_NAME, sessionId:st.sessionId });
  applyGame();
}

function resumeGame() {
  const saved = loadSt();
  if (!saved) return;
  Object.assign(st, saved);
  if (!st.paused) st.startMs = Date.now() - st.elapsed * 1000;
  activeHint = -1;
  applyGame();
}

function applyGame() {
  document.getElementById('g-team').textContent = st.team + ' — ' + BACKPACK_NAME;
  document.getElementById('g-timer').textContent = fmt(st.elapsed);
  document.getElementById('g-timer').className = 'timer-val' + (st.paused ? ' paused' : '');
  document.getElementById('pause-icon').setAttribute('d',
    st.paused ? 'M8 5v14l11-7z' : 'M6 19h4V5H6v14zm8-14v14h4V5h-4z');
  document.getElementById('pause-lbl').textContent = st.paused ? 'Resume' : 'Pause';
  closeHint();
  updateGrid();
  saveSt();
  startTick();
  show('game');
}

function confirmReset() {
  if (!confirm('Reset the timer and all progress?\nThis cannot be undone.')) return;
  resetAll();
}

function resetAll() {
  // 1. Stop the ticker
  clearInterval(ticker);
  ticker = null;
  // 2. Wipe localStorage
  clearSt();
  // 3. Reset all state
  activeHint = -1;
  st = {
    team:'', sessionId:'', startMs:0, elapsed:0,
    paused:false, pausedAt:0, active:false,
    completed: new Array(10).fill(false), hintLog:{}, lockTs:{}
  };
  // 4. Reset UI elements
  document.getElementById('g-timer').textContent = '00:00';
  document.getElementById('g-timer').className = 'timer-val';
  document.getElementById('g-team').textContent = '—';
  document.getElementById('inp-team').value = '';
  document.getElementById('btn-start').disabled = true;
  document.getElementById('btn-resume').style.display = 'none';
  document.getElementById('pause-icon').setAttribute('d', 'M6 19h4V5H6v14zm8-14v14h4V5h-4z');
  document.getElementById('pause-lbl').textContent = 'Pause';
  // 5. Close hint panel, refresh grid
  closeHint();
  updateGrid();
  // 6. Go to setup
  show('setup');
}

function confirmComplete() {
  const done = st.completed.filter(Boolean).length;
  if (!confirm(`Stop the timer and mark as complete?\n\nTime: ${fmt(st.elapsed)}\nLocks solved: ${done}/10`)) return;
  endGame();
}

function endGame() {
  clearInterval(ticker);
  ticker = null;
  st.active = false;
  const done = st.completed.filter(Boolean).length;
  const msg = done === 10
    ? '🏆 Amazing! You solved all 10 locks — a perfect escape!'
    : done >= 7
      ? `Great effort! You solved ${done}/10 locks.`
      : `You solved ${done}/10 locks. Keep at it!`;

  document.getElementById('c-time').textContent  = fmt(st.elapsed);
  document.getElementById('c-team').textContent  = st.team + ' — ' + BACKPACK_NAME;
  document.getElementById('c-locks').textContent = `${done} / 10 locks solved`;
  document.getElementById('c-msg').textContent   = msg;

  logAsync({ event:'complete', teamName:st.team, backpackName:BACKPACK_NAME,
             elapsedSeconds:st.elapsed, locksCompleted:done,
             lockTimestamps:st.lockTs, sessionId:st.sessionId });
  clearSt();
  show('complete');
}

// ═══════════════════════ STORAGE ══════════════════════
function saveSt()  { try { localStorage.setItem(LS_KEY, JSON.stringify(st)); } catch(e) {} }
function loadSt()  { try { const r = localStorage.getItem(LS_KEY); return r ? JSON.parse(r) : null; } catch(e) { return null; } }
function clearSt() { try { localStorage.removeItem(LS_KEY); } catch(e) {} }

// ═══════════════════════ LOGGER ═══════════════════════
function logAsync(p) {
  if (!LOGGER_URL || LOGGER_URL.includes('YOUR_')) return;
  fetch(LOGGER_URL, { method:'POST', mode:'no-cors',
    headers:{'Content-Type':'text/plain'}, body:JSON.stringify(p) }).catch(() => {});
}

// ═══════════════════════ UTILS ════════════════════════
function fmt(s) {
  return String(Math.floor(s / 60)).padStart(2, '0') + ':' + String(s % 60).padStart(2, '0');
}
function show(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('on'));
  document.getElementById('s-' + name).classList.add('on');
}
</script>
